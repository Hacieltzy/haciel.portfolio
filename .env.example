# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# EMAIL_USER: The email address used to send contact form notifications.
EMAIL_USER="hacielcasihan.freelance@gmail.com"

# EMAIL_PASS: The password or App Password for the EMAIL_USER.
# Required for real email sending.
EMAIL_PASS=""
